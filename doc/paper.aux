\@writefile{toc}{\contentsline {subsection}{\numberline {5.3}Spatial Error Distributions}{15}{subsection.5.3}\protected@file@percent }
\newlabel{fig:wss_xy_ad5}{{6a}{16}{AD5 (5\,cm ASD) --- systolic phase}{figure.caption.8}{}}
\newlabel{sub@fig:wss_xy_ad5}{{a}{16}{AD5 (5\,cm ASD) --- systolic phase}{figure.caption.8}{}}
\newlabel{fig:wss_xy_ad6}{{6b}{16}{AD6 (6\,cm ASD) --- systolic phase}{figure.caption.8}{}}
\newlabel{sub@fig:wss_xy_ad6}{{b}{16}{AD6 (6\,cm ASD) --- systolic phase}{figure.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Spatial distribution of WSS magnitude (XY plane, systolic phase) for the 5\,cm (AD5) and 6\,cm (AD6) asymmetric downstream configurations. Each row shows (a) CFD ground truth, (b) PINN prediction, and (c) absolute error. The PINN reproduces elevated WSS concentrations near the aneurysm neck and low WSS within the recirculation zone. Errors remain predominantly below 0.5\,Pa for AD5 and below 0.25\,Pa for AD6, concentrated near geometric transitions and flow impingement sites.}}{16}{figure.caption.8}\protected@file@percent }
\newlabel{fig:spatial_wss}{{6}{16}{Spatial distribution of WSS magnitude (XY plane, systolic phase) for the 5\,cm (AD5) and 6\,cm (AD6) asymmetric downstream configurations. Each row shows (a) CFD ground truth, (b) PINN prediction, and (c) absolute error. The PINN reproduces elevated WSS concentrations near the aneurysm neck and low WSS within the recirculation zone. Errors remain predominantly below 0.5\,Pa for AD5 and below 0.25\,Pa for AD6, concentrated near geometric transitions and flow impingement sites}{figure.caption.8}{}}
\newlabel{fig:pressure_xy_ad5}{{7a}{17}{AD5 (5\,cm ASD) --- systolic phase}{figure.caption.9}{}}
\newlabel{sub@fig:pressure_xy_ad5}{{a}{17}{AD5 (5\,cm ASD) --- systolic phase}{figure.caption.9}{}}
\newlabel{fig:pressure_xy_ad6}{{7b}{17}{AD6 (6\,cm ASD) --- systolic phase}{figure.caption.9}{}}
\newlabel{sub@fig:pressure_xy_ad6}{{b}{17}{AD6 (6\,cm ASD) --- systolic phase}{figure.caption.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Spatial distribution of pressure (XY plane, systolic phase) for the 5\,cm (AD5) and 6\,cm (AD6) asymmetric downstream configurations. Each row shows (a) CFD ground truth, (b) PINN prediction, and (c) absolute error. The PINN captures the pressure gradient from inlet to outlet across both geometries. Errors are distributed throughout the domain with peak values of approximately 14--16\,Pa, modest relative to the overall pressure range of $\sim $225\,Pa (AD5) and $\sim $200\,Pa (AD6).}}{17}{figure.caption.9}\protected@file@percent }
\newlabel{fig:spatial_pressure}{{7}{17}{Spatial distribution of pressure (XY plane, systolic phase) for the 5\,cm (AD5) and 6\,cm (AD6) asymmetric downstream configurations. Each row shows (a) CFD ground truth, (b) PINN prediction, and (c) absolute error. The PINN captures the pressure gradient from inlet to outlet across both geometries. Errors are distributed throughout the domain with peak values of approximately 14--16\,Pa, modest relative to the overall pressure range of $\sim $225\,Pa (AD5) and $\sim $200\,Pa (AD6)}{figure.caption.9}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.4}Diastolic WSS Predictions}{17}{subsection.5.4}\protected@file@percent }
\newlabel{fig:wss_diastolic_ad5}{{8a}{18}{AD5 (5\,cm ASD) --- diastolic phase}{figure.caption.10}{}}
\newlabel{sub@fig:wss_diastolic_ad5}{{a}{18}{AD5 (5\,cm ASD) --- diastolic phase}{figure.caption.10}{}}
\newlabel{fig:wss_diastolic_ad6}{{8b}{18}{AD6 (6\,cm ASD) --- diastolic phase}{figure.caption.10}{}}
\newlabel{sub@fig:wss_diastolic_ad6}{{b}{18}{AD6 (6\,cm ASD) --- diastolic phase}{figure.caption.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Spatial distribution of WSS magnitude (XY plane, diastolic phase) for the 5\,cm (AD5) and 6\,cm (AD6) asymmetric downstream configurations. Each row shows (a) CFD ground truth, (b) PINN prediction, and (c) absolute error. Compared to the systolic phase (Figure~\ref {fig:spatial_wss}), WSS magnitudes are substantially reduced ($\sim $2.0\,Pa peak for AD5 and $\sim $1.2\,Pa for AD6 versus $\sim $6\,Pa during systole), with simpler spatial patterns. Prediction errors remain below 0.25\,Pa for AD5 and below 0.16\,Pa for AD6.}}{18}{figure.caption.10}\protected@file@percent }
\newlabel{fig:wss_diastolic}{{8}{18}{Spatial distribution of WSS magnitude (XY plane, diastolic phase) for the 5\,cm (AD5) and 6\,cm (AD6) asymmetric downstream configurations. Each row shows (a) CFD ground truth, (b) PINN prediction, and (c) absolute error. Compared to the systolic phase (Figure~\ref {fig:spatial_wss}), WSS magnitudes are substantially reduced ($\sim $2.0\,Pa peak for AD5 and $\sim $1.2\,Pa for AD6 versus $\sim $6\,Pa during systole), with simpler spatial patterns. Prediction errors remain below 0.25\,Pa for AD5 and below 0.16\,Pa for AD6}{figure.caption.10}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.5}Three-Dimensional WSS Visualisation}{18}{subsection.5.5}\protected@file@percent }
\newlabel{fig:wss_3d_ad5}{{9a}{19}{AD5 (5\,cm ASD) --- systolic phase}{figure.caption.11}{}}
\newlabel{sub@fig:wss_3d_ad5}{{a}{19}{AD5 (5\,cm ASD) --- systolic phase}{figure.caption.11}{}}
\newlabel{fig:wss_3d_ad6}{{9b}{19}{AD6 (6\,cm ASD) --- systolic phase}{figure.caption.11}{}}
\newlabel{sub@fig:wss_3d_ad6}{{b}{19}{AD6 (6\,cm ASD) --- systolic phase}{figure.caption.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Three-dimensional surface visualisation of WSS magnitude during the systolic phase for the 5\,cm (AD5) and 6\,cm (AD6) asymmetric downstream configurations. Each panel shows the CFD ground truth (left) alongside the PINN prediction (right). The PINN faithfully reproduces the spatial distribution of elevated WSS at the aneurysm neck and the low-WSS regions within the aneurysm sac, capturing the three-dimensional surface patterns relevant to clinical rupture risk assessment.}}{19}{figure.caption.11}\protected@file@percent }
\newlabel{fig:wss_3d}{{9}{19}{Three-dimensional surface visualisation of WSS magnitude during the systolic phase for the 5\,cm (AD5) and 6\,cm (AD6) asymmetric downstream configurations. Each panel shows the CFD ground truth (left) alongside the PINN prediction (right). The PINN faithfully reproduces the spatial distribution of elevated WSS at the aneurysm neck and the low-WSS regions within the aneurysm sac, capturing the three-dimensional surface patterns relevant to clinical rupture risk assessment}{figure.caption.11}{}}
