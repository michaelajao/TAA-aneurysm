\newlabel{fig:training_ad5}{{5a}{14}{AD5 (5\,cm ASD)}{figure.caption.6}{}}
\newlabel{sub@fig:training_ad5}{{a}{14}{AD5 (5\,cm ASD)}{figure.caption.6}{}}
\newlabel{fig:training_ad6}{{5b}{14}{AD6 (6\,cm ASD)}{figure.caption.6}{}}
\newlabel{sub@fig:training_ad6}{{b}{14}{AD6 (6\,cm ASD)}{figure.caption.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Training convergence for the 5\,cm (AD5) and 6\,cm (AD6) asymmetric downstream configurations. Top row: total loss over epochs on a logarithmic scale. Bottom row: individual component losses (WSS, physics, no-slip BC, pressure, inlet BC, outlet BC). Both configurations exhibit rapid initial convergence within the first 500 epochs, followed by steady refinement. The physics loss decreases consistently throughout training, confirming enforcement of the RANS conservation laws.}}{14}{figure.caption.6}\protected@file@percent }
\newlabel{fig:training}{{5}{14}{Training convergence for the 5\,cm (AD5) and 6\,cm (AD6) asymmetric downstream configurations. Top row: total loss over epochs on a logarithmic scale. Bottom row: individual component losses (WSS, physics, no-slip BC, pressure, inlet BC, outlet BC). Both configurations exhibit rapid initial convergence within the first 500 epochs, followed by steady refinement. The physics loss decreases consistently throughout training, confirming enforcement of the RANS conservation laws}{figure.caption.6}{}}
